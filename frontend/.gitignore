# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Local-only (do not push)
.gitignore
main.py

# Python (if any scripts land in frontend)
# We keep a narrow rule here since frontend is primarily TypeScript/TSX.
# Avoid broad rules in the root .gitignore.
script.py.mako
**/script.py.mako
__pycache__/
*.py[cod]
*.pyo
*.pyd

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
.turbo/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env*.local
.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts