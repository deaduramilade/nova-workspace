# =============================================================================
# Nova Production — Docker Compose root .env
# Copy to project root as .env
#
# Generate automatically:
#   python3 deploy/generate_secrets.py --domain your-domain.com --profile oracle --write
#
# Oracle deploy: docker compose -f docker-compose.oracle.yml up -d --build
# Generic deploy: docker compose -f docker-compose.prod.yml up -d --build
# =============================================================================

# --- Deployment profile ---
DEPLOY_PROFILE=default

# --- Infrastructure passwords (must match backend/.env) ---
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD
REDIS_PASSWORD=REPLACE_WITH_STRONG_REDIS_PASSWORD
NEKO_PASSWORD=REPLACE_WITH_STRONG_NEKO_PASSWORD
NEKO_ADMIN_PASSWORD=REPLACE_WITH_STRONG_ADMIN_PASSWORD

# --- Public URLs (used at frontend build time) ---
NEXT_PUBLIC_API_URL=https://your-domain.com/api/v1
NEXT_PUBLIC_WS_URL=wss://your-domain.com
NEXT_PUBLIC_APP_ENV=production

# --- TLS / domain (update deploy/nginx.conf server_name to match) ---
DOMAIN=your-domain.com