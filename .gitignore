# ========================================
node_modules/
**/node_modules/

.next/
**/.next/
out/
**/out/
.turbo/
.vercel/

# TypeScript / ESLint caches
*.tsbuildinfo
.eslintcache

# Next.js auto-generated (recreated on build)
