# ========================================
# Repo-local files (do not push)
# ========================================
.gitignore
**/.gitignore
main.py
**/main.py

# ========================================
# Python / FastAPI backend
# ========================================
*.py
script.py.mako
**/script.py.mako

__pycache__/
*.py[cod]
*.pyo
*.pyd
*$py.class
*.so
.Python

# Virtual environments (root or nested)
.venv/
venv/
ENV/
env/
backend/.venv/

# Test / type / lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
htmlcov/
.coverage
coverage/
*.cover
.tox/
.nox/

# Distribution / packaging
dist/
build/
*.egg-info/
.eggs/
pip-log.txt
pip-delete-this-directory.txt

# Celery
celerybeat-schedule
celerybeat.pid

# ========================================
