# =============================================================================
# Nova Workspace — Professional .gitignore
# =============================================================================
#
# Project: Nova — AI-native collaborative browser workspace
# Charter: docs/charter.md (v2.2, Phase 4 – Production Readiness)
# Repository: https://github.com/deaduramilade/nova-workspace
# License: Apache-2.0
#
# This file supports:
# - Strong security & compliance (never commit secrets, keys, credentials)
# - Docker-based deployments (Oracle, self-hosted, production)
# - Full stack: Python/FastAPI/Alembic + Next.js + Neko + Ollama
# =============================================================================

# -----------------------------------------------------------------------------
# Python Backend
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*$py.class
*.so
.Python

# Packaging & build
*.egg
*.egg-info/
dist/
build/
.eggs/
pip-log.txt
pip-delete-this-directory.txt

# Testing, linting & coverage
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
htmlcov/
.coverage
coverage/
*.cover
.tox/
.nox/

# Celery
celerybeat-schedule
celerybeat.pid

# Virtual environments
.venv/
venv/
ENV/
env/
backend/.venv/
frontend/.venv/

# -----------------------------------------------------------------------------
# Alembic Migrations (Must be committed)
# -----------------------------------------------------------------------------
!alembic/
!**/alembic/
!alembic/env.py
!alembic/script.py.mako
!alembic/versions/
!alembic/versions/*.py

# Only ignore stray mako templates outside of any alembic/ directory.
# (The real alembic/script.py.mako inside the migration setup must be kept.)
script.py.mako
**/script.py.mako

# -----------------------------------------------------------------------------
# Frontend (Next.js)
# -----------------------------------------------------------------------------
node_modules/
**/node_modules/

.next/
**/.next/
out/
**/out/
.turbo/
.vercel/

*.tsbuildinfo
.eslintcache
frontend/next-env.d.ts

# -----------------------------------------------------------------------------
# Docker & Deployment
# -----------------------------------------------------------------------------
docker-compose.override.yml
docker-compose.*.local.yml
volumes/
deploy/certs/
deploy/certs/**/*

# -----------------------------------------------------------------------------
# Secrets & Security (Critical)
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
backend/.env
frontend/.env
frontend/.env.local
.env.example
**/.env.example

*.pem
*.key
*.crt
id_rsa
id_ed25519
id_ed25519.pub
*.p12
*.pfx

*secret*
*password*
*token*

# -----------------------------------------------------------------------------
# Databases & Storage
# -----------------------------------------------------------------------------
*.sqlite
*.sqlite3
*.db
*.rdb
*.pid

# -----------------------------------------------------------------------------
# IDE, Editor & AI Tools
# -----------------------------------------------------------------------------
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.swp
*.swo
*~

.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# AI assistant files
CLAUDE.md
AGENTS.md
.cursor/
.grok/
.grok/**

# -----------------------------------------------------------------------------
# Logs & OS Files
# -----------------------------------------------------------------------------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.bak
*.tmp
*.temp
.cache/
**/.cache/

# =============================================================================
# Force-include critical Alembic files (placed at end so they win over any prior rules)
# =============================================================================
# Alembic is essential for database migrations.
# - Backend/alembic.ini configures Alembic
# - Backend/alembic/env.py is customized to load our FastAPI models + settings
# - Backend/alembic/versions/*.py contain the migration history
# In production these are required (see docker-entrypoint.sh + RUN_DB_MIGRATIONS)
!alembic/
!**/alembic/
!alembic.ini
!**/alembic.ini
!Backend/alembic/
!Backend/alembic.ini
!**/alembic/env.py
!**/alembic/script.py.mako
!**/alembic/versions/
!**/alembic/versions/*.py
!**/alembic/README
!Backend/alembic/README